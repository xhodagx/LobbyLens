<Window x:Class="LobbyLens.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LobbyLens Settings"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True">
    <StackPanel Margin="16" Width="300">
        <TextBlock x:Name="UpdateText" Visibility="Collapsed" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,10">
            <Hyperlink Click="UpdateLink_Click">Update available — download it here</Hyperlink>
        </TextBlock>
        <TextBlock x:Name="StagedText" Visibility="Collapsed" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,10"
                   Text="Update installed — restart HDT to apply."/>

        <TextBlock x:Name="FontLabel" Text="Font size: 20" FontWeight="Bold"/>
        <Slider x:Name="FontSlider" Minimum="12" Maximum="40" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="FontSlider_ValueChanged" Margin="0,2,0,10"/>

        <TextBlock x:Name="OpacityLabel" Text="Opacity: 100%" FontWeight="Bold"/>
        <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="OpacitySlider_ValueChanged" Margin="0,2,0,10"/>

        <TextBlock x:Name="ScaleLabel" Text="Panel scale: 1.00×" FontWeight="Bold"/>
        <Slider x:Name="ScaleSlider" Minimum="0.5" Maximum="3.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="ScaleSlider_ValueChanged" Margin="0,2,0,10"/>

        <CheckBox x:Name="SortByPlaceBox" Content="Order by current standings" Checked="SortByPlaceBox_Changed" Unchecked="SortByPlaceBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="BestFirstBox" Content="Show best rating first (when not by standings)" Checked="BestFirstBox_Changed" Unchecked="BestFirstBox_Changed" Margin="0,2,0,6"/>
        <CheckBox x:Name="DebugBox" Content="Verbose debug logging" Checked="DebugBox_Changed" Unchecked="DebugBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="AutoUpdateBox" Content="Install updates automatically (on HDT restart)" Checked="AutoUpdateBox_Changed" Unchecked="AutoUpdateBox_Changed" Margin="0,2,0,10"/>

        <TextBlock Text="Features" FontWeight="Bold" Margin="0,2,0,4"/>
        <CheckBox x:Name="RankNumbersBox" Content="Leaderboard rank numbers (#)" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="HeroInfoBox" Content="Hero, tier and health" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="CompsBox" Content="Board minion types" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="EliminationsBox" Content="Mark eliminated players" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="NextOpponentBox" Content="Mark next combat opponent (next)" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,4"/>
        <CheckBox x:Name="SessionBox" Content="Session line (games, avg place, net MMR)" Checked="FeatureBox_Changed" Unchecked="FeatureBox_Changed" Margin="0,2,0,12"/>

        <TextBlock Text="Privacy" FontWeight="Bold" Margin="0,2,0,4"/>
        <CheckBox x:Name="ReportMatchesBox" Content="Contribute anonymous match data" Checked="ReportBox_Changed" Unchecked="ReportBox_Changed" Margin="0,2,0,2"/>
        <TextBlock Text="Helps build hero/comp stats. Battletags are hashed — never sent. No personal data leaves your PC." TextWrapping="Wrap" FontSize="11" Foreground="#FF888888" Margin="20,0,0,12"/>

        <Button x:Name="ResetButton" Content="Reset panel position and size" Click="ResetButton_Click" Padding="6,4"/>

        <StackPanel x:Name="SupportPanel" Visibility="Collapsed" Margin="0,14,0,0">
            <TextBlock Text="Support LobbyLens" FontWeight="Bold" Margin="0,0,0,2"/>
            <TextBlock Text="LobbyLens is free and ad-free. If it helps you climb, a tip keeps it running." TextWrapping="Wrap" FontSize="11" Foreground="#FF888888" Margin="0,0,0,6"/>
            <Button x:Name="KofiButton" Content="Tip on Ko-fi ♥" Visibility="Collapsed" Click="KofiButton_Click" Padding="6,4" Margin="0,0,0,6"/>
            <DockPanel x:Name="LightningRow" Visibility="Collapsed" Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Content="Copy" Click="CopyLightning_Click" Padding="8,2" Margin="6,0,0,0"/>
                <TextBlock DockPanel.Dock="Left" Text="⚡" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Bitcoin Lightning — best for small tips"/>
                <TextBox x:Name="LightningText" IsReadOnly="True" FontSize="11" VerticalContentAlignment="Center"/>
            </DockPanel>
            <DockPanel x:Name="BtcRow" Visibility="Collapsed" Margin="0,0,0,2">
                <Button DockPanel.Dock="Right" Content="Copy" Click="CopyBtc_Click" Padding="8,2" Margin="6,0,0,0"/>
                <TextBlock DockPanel.Dock="Left" Text="₿" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Bitcoin on-chain — best for larger tips (network fees apply)"/>
                <TextBox x:Name="BtcText" IsReadOnly="True" FontSize="11" VerticalContentAlignment="Center"/>
            </DockPanel>
        </StackPanel>
    </StackPanel>
</Window>
